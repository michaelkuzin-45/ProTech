    <script>
        const pages = ['home', 'repairs', 'rentals', 'rental-request', 'sales', 'contact'];
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        function navigate() {
            let hash = window.location.hash.substring(1);
            if (!pages.includes(hash)) hash = 'home';

            pages.forEach((p) => {
                const el = document.getElementById('page-' + p);
                if (!el) return;
                if (p === hash) {
                    el.classList.remove('hidden');
                    el.classList.add('block', 'page-enter');
                } else {
                    el.classList.add('hidden');
                    el.classList.remove('block', 'page-enter');
                }
            });

            document.querySelectorAll('.desktop-nav-link').forEach((link) => {
                const active = link.getAttribute('href') === '#' + hash;
                link.classList.toggle('text-slate-100', active);
                link.classList.toggle('text-slate-400', !active);
            });

            document.querySelectorAll('.mobile-nav-link').forEach((link) => {
                const active = link.getAttribute('href') === '#' + hash;
                link.classList.toggle('text-slate-100', active);
                link.classList.toggle('font-medium', active);
                link.classList.toggle('text-slate-400', !active);
            });

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function setButtonState(button, label) {
            if (!button) return;
            button.textContent = label;
            button.disabled = true;
            button.setAttribute('aria-disabled', 'true');
        }

        function lockForm(formElement) {
            if (!formElement) return;
            formElement.querySelectorAll('input, textarea, select, button').forEach((el) => {
                el.disabled = true;
            });
        }

        window.addEventListener('hashchange', navigate);
        window.addEventListener('load', navigate);

        if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                const isHidden = mobileMenu.classList.toggle('hidden');
                mobileMenuBtn.setAttribute('aria-expanded', String(!isHidden));
            });
        }

        document.querySelectorAll('.mobile-nav-link').forEach((link) => {
            link.addEventListener('click', () => {
                if (mobileMenu) mobileMenu.classList.add('hidden');
                if (mobileMenuBtn) mobileMenuBtn.setAttribute('aria-expanded', 'false');
            });
        });

        // Demo-only forms. These do not send data anywhere yet.
        const form = document.getElementById('contact-form');
        const successBanner = document.getElementById('form-success');
        const submitBtn = document.getElementById('submit-btn');

        if (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                setButtonState(submitBtn, 'Sending...');

                window.setTimeout(() => {
                    successBanner?.classList.remove('hidden');
                    successBanner?.classList.add('flex');
                    if (submitBtn) {
                        submitBtn.textContent = 'Sent Successfully';
                        submitBtn.classList.replace('bg-slate-100', 'bg-white/[0.05]');
                        submitBtn.classList.replace('text-[#06080c]', 'text-slate-500');
                        submitBtn.classList.remove('hover:bg-white', 'hover:-translate-y-0.5', 'hover:shadow-[0_0_30px_rgba(255,255,255,0.2)]');
                    }
                    lockForm(form);
                }, 800);
            });
        }

        const rentalForm = document.getElementById('rental-request-form');
        const rentalSuccessBanner = document.getElementById('rental-form-success');
        const rentalSubmitBtn = document.getElementById('rental-submit-btn');

        if (rentalForm) {
            rentalForm.addEventListener('submit', function (e) {
                e.preventDefault();
                setButtonState(rentalSubmitBtn, 'Submitting Request...');

                window.setTimeout(() => {
                    rentalSuccessBanner?.classList.remove('hidden');
                    rentalSuccessBanner?.classList.add('flex');
                    if (rentalSubmitBtn) {
                        rentalSubmitBtn.textContent = 'Request Submitted';
                        rentalSubmitBtn.classList.replace('bg-slate-100', 'bg-white/[0.05]');
                        rentalSubmitBtn.classList.replace('text-[#06080c]', 'text-slate-500');
                        rentalSubmitBtn.classList.remove('hover:bg-white', 'hover:-translate-y-0.5', 'hover:shadow-[0_0_30px_rgba(255,255,255,0.2)]');
                    }
                    lockForm(rentalForm);
                }, 1000);
            });
        }
    </script>

</body></html>
